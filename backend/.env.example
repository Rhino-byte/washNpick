# App
APP_ENV=development
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Neon PostgreSQL (use pooled connection string)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/washnpick?sslmode=require

# Firebase (Google auth) — service account JSON fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Pricing (KES)
PRICE_WASH_FOLD_PER_KG=50
PRICE_DUVET_KING_QUEEN=700
PRICE_DOUBLE_DUVET=500
BURNED_USER_DEPOSIT_PERCENT=50
CURRENCY=KES
MIN_WEIGHT_KG=1
MAX_WEIGHT_KG=50

# M-Pesa Daraja
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:8000/api/v1/payments/mpesa/callback
MPESA_ENV=sandbox

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+15559653603
PUBLIC_API_BASE_URL=
TWILIO_AUTH_TOKEN_VALIDATION=true
STAFF_ESCALATION_PHONES=

# OpenAI WhatsApp bot
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
WHATSAPP_BOT_ENABLED=true
TWILIO_MPS_LIMIT=80
WHATSAPP_BOT_HISTORY_LIMIT=12

# Google Maps (Phase 3)

GOOGLE_MAPS_API_KEY= 

# Service area center (Ololulunga) — radius km for coverage check
SERVICE_AREA_LAT=-0.7500
SERVICE_AREA_LNG=35.2500
SERVICE_AREA_RADIUS_KM=15

# Admin (legacy secret — media uploads use ADMIN_UPLOAD_SECRET on frontend)
ADMIN_API_SECRET=

# Staff dashboard — comma-separated Firebase UIDs (bootstrap + emergency revoke)
STAFF_FIREBASE_UIDS=
